# Valeurs de repli pour le build — les vraies valeurs doivent être configurées
# dans les paramètres du projet Vercel (elles remplacent ce fichier).
# AUTH_SECRET est requis par NextAuth v5 pour initialiser le middleware au build time.
AUTH_SECRET=build-time-placeholder-set-real-value-in-vercel-project-settings-00
# POSTGRES_URL est requis par app/db.ts qui initialise postgres() au niveau module.
POSTGRES_URL=postgres://build_placeholder:placeholder@localhost:5432/placeholder
